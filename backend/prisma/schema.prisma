generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  manager
  artisan
}

enum WorkstationType {
  standard
  premium
  pressure_pot
  vacuum_chamber
  studio
}

enum WorkstationStatus {
  available
  pouring
  curing
  maintenance
  offline
}

enum BatchStatus {
  scheduled
  in_progress
  completed
  failed
}

enum PourType {
  countertop
  river_table
  jewelry
  coaster
  charcuterie
  custom
}

enum MaintenancePriority {
  low
  medium
  high
  urgent
}

enum MaintenanceStatus {
  open
  in_progress
  completed
  cancelled
}

enum CuringCategory {
  humidity_check
  temperature_log
  mold_prep
  pigment_mix
  inventory
  other
}

enum CuringStatus {
  scheduled
  in_progress
  completed
  overdue
}

enum WorkshopCategory {
  pour_session
  class_rental
  custom_commission
  material_sale
  custom_work
  other
}

enum WorkshopRateStatus {
  active
  upcoming
  archived
}

enum MoldOrderStatus {
  pending
  in_progress
  completed
  delivered
}

model ResinStudio {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  totalWorkstations  Int      @default(6) @map("total_workstations")
  timezone    String   @default("America/Chicago")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            User[]
  workstations            Workstation[]
  pourBatches    PourBatch[]
  equipmentRepairs  EquipmentRepair[]
  curingChecklists  CuringChecklist[]
  workshopRates      WorkshopRate[]
  moldOrders       MoldOrder[]

  @@map("resin_studios")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  role            UserRole @default(owner)
  resinStudioId String   @map("resin_studio_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Workstation {
  id              String     @id @default(uuid())
  resinStudioId String     @map("resin_studio_id")
  name            String
  zone            String
  workstationType        WorkstationType   @default(standard) @map("workstation_type")
  workstationModel       String?    @map("workstation_model")
  status          WorkstationStatus @default(available)
  notes           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  resinStudio   ResinStudio     @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)
  pourBatches   PourBatch[]
  equipmentRepairs EquipmentRepair[]

  @@unique([resinStudioId, name])
  @@index([resinStudioId, status])
  @@map("workstations")
}

model PourBatch {
  id              String      @id @default(uuid())
  resinStudioId String      @map("resin_studio_id")
  workstationId          String      @map("workstation_id")
  scheduledAt     DateTime    @map("scheduled_at")
  pouringType      PourType  @default(countertop) @map("pouring_type")
  cashAmount      Float       @default(0) @map("cash_amount")
  cardAmount      Float       @default(0) @map("card_amount")
  pieceCount       Int         @default(1) @map("piece_count")
  hardenerRatio  Float       @default(0) @map("hardener_ratio")
  status          BatchStatus @default(scheduled)
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)
  workstation          Workstation          @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@index([resinStudioId, scheduledAt])
  @@index([resinStudioId, status])
  @@map("pour_batches")
}

model EquipmentRepair {
  id              String              @id @default(uuid())
  resinStudioId String              @map("resin_studio_id")
  workstationId          String              @map("workstation_id")
  title           String
  description     String?
  reportedAt      DateTime            @map("reported_at")
  completedAt     DateTime?           @map("completed_at")
  priority        MaintenancePriority @default(medium)
  status          MaintenanceStatus   @default(open)
  cost            Float?
  notes           String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)
  workstation          Workstation          @relation(fields: [workstationId], references: [id], onDelete: Cascade)

  @@index([resinStudioId, status])
  @@index([resinStudioId, priority])
  @@map("equipment_repairs")
}

model CuringChecklist {
  id              String        @id @default(uuid())
  resinStudioId String        @map("resin_studio_id")
  title           String
  description     String?
  category        CuringCategory @default(other)
  zone            String?
  scheduledAt     DateTime      @map("scheduled_at")
  status          CuringStatus   @default(scheduled)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)

  @@index([resinStudioId, scheduledAt])
  @@map("curing_checklists")
}

model WorkshopRate {
  id              String           @id @default(uuid())
  resinStudioId String           @map("resin_studio_id")
  title           String
  rateCategory    WorkshopCategory   @default(pour_session) @map("rate_category")
  status          WorkshopRateStatus @default(active)
  basePrice       Float            @map("base_price")
  priceMultiplier Float            @default(1.0) @map("price_multiplier")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)

  @@index([resinStudioId, rateCategory])
  @@map("workshop_rates")
}

model MoldOrder {
  id              String          @id @default(uuid())
  resinStudioId String          @map("resin_studio_id")
  customerName    String          @map("customer_name")
  moldType        String          @map("mold_type")
  supplierName    String?         @map("supplier_name")
  status          MoldOrderStatus @default(pending)
  price           Float           @default(0)
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  resinStudio ResinStudio @relation(fields: [resinStudioId], references: [id], onDelete: Cascade)

  @@index([resinStudioId, status])
  @@map("mold_orders")
}
